    "version": "0.2.0",
    "configurations": [
        {
            "name": "Arm Debugger",
            "type": "arm-debugger",
            "request": "launch",
            "connectionAddress": "${command:device-manager.getSerialNumber}",
            "programs": [
                "${command:arm-debugger.getApplicationFile}"
