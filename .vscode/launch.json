            "cmsisPack": "${command:device-manager.getDevicePack}",
            "deviceName": "${command:device-manager.getDeviceName}",
            "processorName": "${command:cmsis-csolution.getProcessorName}",
            "connectionType": "ST-Link",
            "debugPortMode": "SWD"
        },
        {
            "name": "Arm Debugger",
            "type": "arm-debugger",
            "request": "launch",
            "connectionAddress": "${command:device-manager.getSerialNumber}",
            "programs": [
                "${command:arm-debugger.getApplicationFile}"
            ],
            "cmsisPack": "${command:device-manager.getDevicePack}"
        }
    ]
}